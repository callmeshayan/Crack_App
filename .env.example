# Example environment variables
# Copy this file to .env and fill in your actual values

RF_API_KEY=your_roboflow_api_key_here
RF_WORKSPACE=your_workspace_name
RF_WORKFLOW_ID=your_workflow_id
RF_MODEL_ID=1
RF_CONF=0.5
RF_INFER_FPS=2.0
RF_SAVE_COOLDOWN=0.5
RF_ONLY_CLASS=crack
RF_SHOW_PREVIEW=1
RF_SMALL_MAX_PX2=6000
RF_MEDIUM_MAX_PX2=20000
