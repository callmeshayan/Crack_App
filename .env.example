# Example environment variables
# Copy this file to .env and fill in your actual values

RF_API_KEY=your_roboflow_api_key_here
RF_WORKSPACE=your_workspace_name
RF_WORKFLOW_ID=your_workflow_id
RF_MODEL_ID=1

# Detection settings
RF_CONF=0.4                    # Lower = more detections (0.0-1.0)
RF_INFER_FPS=5.0              # Higher = faster detection (1-10 recommended)
RF_SAVE_COOLDOWN=0.2          # Lower = save more frequently (seconds)
RF_ONLY_CLASS=crack
RF_SHOW_PREVIEW=1

# Size thresholds (in pixels²)
RF_SMALL_MAX_PX2=6000
RF_MEDIUM_MAX_PX2=20000

# Save options
RF_SAVE_TO_ALL_DIRS=1         # 1=save to all dirs, 0=size-categorized only
